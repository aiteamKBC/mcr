openapi: 3.0.3
info:
  title: MCR API
  version: 1.0.0
  description: Monthly Coach Review endpoints
paths:
  /api/mcr/reviews/:
    get:
      operationId: api_mcr_reviews_list
      tags:
      - api
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/DashboardMcrReviewDetail'
          description: ''
  /api/mcr/reviews/{id}/:
    get:
      operationId: api_mcr_reviews_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        required: true
      tags:
      - api
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DashboardMcrReviewDetail'
          description: ''
  /api/mcr/reviews/{id}/booking_session/:
    get:
      operationId: api_mcr_reviews_booking_session_list
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        required: true
      tags:
      - api
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/BookingSession'
          description: ''
  /api/mcr/reviews/{id}/created_at/:
    get:
      operationId: api_mcr_reviews_created_at_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        required: true
      tags:
      - api
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: object
                additionalProperties: {}
          description: ''
  /api/mcr/reviews/{id}/export/:
    get:
      operationId: api_mcr_reviews_export_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        required: true
      tags:
      - api
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: string
                format: binary
          description: ''
  /api/mcr/reviews/{id}/status/:
    get:
      operationId: api_mcr_reviews_status_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        required: true
      tags:
      - api
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: object
                additionalProperties: {}
          description: ''
  /api/mcr/reviews/{id}/summary_json/:
    get:
      operationId: api_mcr_reviews_summary_json_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        required: true
      tags:
      - api
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: object
                additionalProperties: {}
          description: ''
