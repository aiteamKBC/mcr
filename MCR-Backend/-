components:
  schemas:
    BookingSession:
      type: object
      properties:
        id:
          type: integer
        case_owner_id:
          type: integer
          nullable: true
        day_date:
          type: string
          format: date
          nullable: true
        booking_id:
          type: string
          nullable: true
        service_name:
          type: string
          nullable: true
        meeting_subject:
          type: string
          nullable: true
        customer_name:
          type: string
          nullable: true
        customer_email:
          type: string
          nullable: true
        duration_seconds:
          type: integer
          nullable: true
        total_participant_count:
          type: integer
          nullable: true
        staff_names:
          type: string
          nullable: true
        staff_emails:
          type: string
          nullable: true
        created_at:
          type: string
          format: date-time
          nullable: true
        updated_at:
          type: string
          format: date-time
          nullable: true
      required:
      - id
    DashboardMcrReviewDetail:
      type: object
      properties:
        id:
          type: integer
        date:
          type: string
          format: date
          nullable: true
        programme:
          type: string
          default: ''
        group:
          type: string
          default: ''
        meeting_link:
          type: string
          default: ''
        total_duration_min:
          type: integer
          default: 0
        coach_name:
          type: string
          default: ''
        learner_name:
          type: string
          default: ''
        rag_status:
          type: string
          default: amber
        qualitative_rating:
          type: string
          default: ''
        created_at:
          type: string
          format: date-time
          nullable: true
        updated_at:
          type: string
          format: date-time
          nullable: true
        safeguarding_flagged:
          type: boolean
          default: false
        satisfaction_score:
          type: integer
          nullable: true
        executive_summary:
          type: string
          default: ''
        strengths:
          type: array
          items:
            type: string
        priority_actions: {}
        overall_rating: {}
        qa: {}
        booking_id:
          type: string
          nullable: true
        status:
          type: string
        summary_text_raw:
          type: string
          default: ''
        summary_text_json:
          nullable: true
        summary_json:
          nullable: true
      required:
      - id
  securitySchemes:
    basicAuth:
      type: http
      scheme: basic
    cookieAuth:
      type: apiKey
      in: cookie
      name: sessionid
